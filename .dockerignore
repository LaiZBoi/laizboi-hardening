# .dockerignore — what NOT to copy into the build context.
#
# Be deliberate about excludes: docs/ROADMAP.md is loaded at RUNTIME
# (see core/views.py — public /core/roadmap/ + /core/roadmap.json),
# so we keep docs/ in the image. Mobile + Play-publisher tooling
# stays OUT — those are local-only and weren't even on GitHub.

# ─── Git ─────────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes
.dev-worktree/

# ─── Python ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv/
*.egg-info/
.eggs/
*.egg
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.tox/
.mypy_cache/
.ruff_cache/

# ─── Secrets / local config ──────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Local-only / not-on-GitHub ──────────────────────────────────────
mobile/
mobile-app/
local_apps/play_publish/
backups/

# ─── Runtime / generated data ────────────────────────────────────────
db.sqlite3
db.sqlite3-journal
media/
static_collected/
logs/
*.log

# ─── Docker self-references ──────────────────────────────────────────
# (no need to ship the Dockerfile / compose files inside the image)
Dockerfile*
docker-compose*.yml
.dockerignore

# ─── CI / IDE / OS noise ─────────────────────────────────────────────
.github/
.gitlab-ci.yml
.travis.yml
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ─── Misc build artifacts ────────────────────────────────────────────
build/
dist/
*.whl
tmp/
temp/
*.tmp
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
