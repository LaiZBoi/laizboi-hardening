# Client St0r self-hosted environment template
#
# Docker:  cp .env.example .env  →  see docs/docker.md
# VPS:      sudo cp .env.example /etc/clientst0r/.env  →  see docs/deployment-vps.md
#
# Do not commit `.env`. Generate unique secrets for every install.

# Core Django settings
DEBUG=False
SECRET_KEY=
APP_MASTER_KEY=
API_KEY_SECRET=

# Database
# Docker Compose: DB_HOST=db (default in compose)
# VPS:           DB_HOST=127.0.0.1
DB_ENGINE=mysql
DB_NAME=clientst0r
DB_USER=clientst0r
DB_PASSWORD=
DB_ROOT_PASSWORD=
DB_HOST=db
DB_PORT=3306

# Public URL and host validation (localhost/127.0.0.1 required for Docker healthchecks)
ALLOWED_HOSTS=psa.laizboi.com,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://psa.laizboi.com
BASE_URL=https://psa.laizboi.com

# HTTPS and cookies (set SECURE_* False for local Docker on :8000 without TLS)
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Authentication policy
REQUIRE_2FA=True
SESSION_COOKIE_AGE=28800
SESSION_EXPIRE_AT_BROWSER_CLOSE=True
SESSION_IDLE_TIMEOUT=3600
AXES_FAILURE_LIMIT=5
AXES_COOLOFF_TIME=1

# Update behavior — safe default: execution is opt-in only
AUTO_UPDATE_ENABLED=False
GITHUB_REPO_OWNER=LaiZBoi
GITHUB_REPO_NAME=laizboi-hardening
GITHUB_TOKEN=

# Beta signup forwarding — safe default: blank (no off-instance forwarding)
BETA_ADMIN_EMAIL=
BETA_UPSTREAM_URL=

# Storage paths
UPLOAD_ROOT=/var/lib/clientst0r/uploads
# nginx (Docker / Nginx VPS) or apache (Apache VPS with mod_xsendfile)
PRIVATE_FILE_SERVER=nginx

# Docker Compose ports / image (ignored on bare-metal VPS)
WEB_PORT=8000
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
CLIENTST0R_IMAGE=
# Optional first-boot superuser (Docker entrypoint only)
DJANGO_SUPERUSER_USERNAME=
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=

# Email / SMTP
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# Optional password breach checking (opt-in; calls api.pwnedpasswords.com when enabled)
HIBP_ENABLED=False
HIBP_API_KEY=
HIBP_CHECK_ON_SAVE=True
HIBP_BLOCK_BREACHED=False
HIBP_SCAN_FREQUENCY=24

# Optional AI providers
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5-20250929
MOONSHOT_API_KEY=
MOONSHOT_MODEL=moonshot-v1-8k
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_MODEL=abab6.5-chat
MINIMAX_CODING_API_KEY=
MINIMAX_CODING_MODEL=MiniMax-M2.5
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Optional maps and property data APIs
GOOGLE_MAPS_API_KEY=
MAPBOX_ACCESS_TOKEN=
BING_MAPS_API_KEY=
REGRID_API_KEY=
ATTOM_API_KEY=
MAP_DEFAULT_ZOOM=4
MAP_DRAGGING_ENABLED=true

# Integration SSRF policy
ALLOW_PRIVATE_IP_INTEGRATIONS=False
